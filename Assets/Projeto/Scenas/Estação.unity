  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "S\xEDmbolos crescem.\n\nEles surgem pelo desenvolvimento a partir de outros
    signos, particularmente de \xEDcones.\n\nPensamos somente por meio de signos.
    Esses signos mentais possuem natureza mista.\n\nEnt\xE3o \xE9 s\xF3 a partir
    de s\xEDmbolos que um novo s\xEDmbolo pode crescer.\n\nOmne symbolum de symbolo.\nUm
    s\xEDmbolo, uma vez existente, espalha-se entre os povos. \n\nNo uso e na experi\xEAncia,
    seu significado cresce.\n\nCharles Sanders Peirce (1839-1914), fil\xF3sofo e
    semioticista\nCP2.302, circa 1895"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 76191763a3940c741ab5ad08738eace8, type: 2}
